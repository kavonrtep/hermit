#!/usr/bin/env bash
# Guard wrapper for conda — blocks bare 'conda install', passes everything else
# Part of hermit's defense-in-depth for software installation control.
# Works for both Claude Code and Codex CLI.

# Find real conda binary (skip /opt/hermit/bin to avoid recursion)
real=$(PATH="${PATH/\/opt\/hermit\/bin:/}" command -v conda 2>/dev/null)
[[ -z "$real" ]] && { echo "Error: conda not found on PATH" >&2; exit 127; }

# htool sets this to bypass the guard
[[ "${_HTOOL_BYPASS:-}" == "1" ]] && exec "$real" "$@"

# Block 'conda install' — allow create, activate, info, list, etc.
if [[ "${1:-}" == "install" ]]; then
    echo "BLOCKED: bare 'conda install' is not allowed." >&2
    echo "" >&2
    echo "Use 'htool <package>' instead — it searches all environments first," >&2
    echo "then installs to an isolated conda env with proper logging." >&2
    echo "" >&2
    echo "For multi-package environments, use:" >&2
    echo "  mamba create -y -p /envs/conda/envs/NAME -c bioconda -c conda-forge PKG1 PKG2" >&2
    exit 1
fi

exec "$real" "$@"
