# Copy to .env and edit:  cp env.template .env

# =============================================================================
# DATA PATHS (external — must be set per server/project)
# =============================================================================
# Paths are mounted at their ORIGINAL locations inside the container.
# INPUT_DIRS: comma-separated list of read-only data directories.
# OUTPUT_DIR: writable results (ideally same physical drive as input).

INPUT_DIRS=/mnt/ceph/454_data
OUTPUT_DIR=/mnt/ceph/users/yourname/results
REFS_DIR=/mnt/ceph/references

# =============================================================================
# INTERNAL PATHS (optional — default to project subdirectories)
# =============================================================================
# WORKSPACE_DIR=./workspace       # or: ln -sfn /local/ssd/scratch ./workspace
# ENVS_DIR=./envs
# CONFIG_DIR=./config

# --- Singularity image ---
# SIF_IMAGE=./bioinfo-agent.sif

# --- Instance name ---
# INSTANCE_NAME=hermit

# --- Resource limits (optional — auto-detected if not set) ---
# USER_CPUS=8
# USER_MEMORY=64G

# --- API keys (OPTIONAL — only if NOT using subscription auth) ---
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx
